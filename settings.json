{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)"
    ],
    "deny": [
      "Read(~/**)",
      "Read(//c/**)",
      "Edit(~/**)",
      "Edit(//c/**)",
      "Write(~/**)",
      "Write(//c/**)",
      "Bash(cd ..*)",
      "Bash(cd \\*)",
      "Bash(cd /*)",
      "Bash(type C:\\*)",
      "Bash(Get-Content C:\\*)"
    ]
  }
}